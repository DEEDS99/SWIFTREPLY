{
  "name": "swiftreply-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "SwiftReply \u2014 AI WhatsApp Business Messaging Platform",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:mac": "tauri build --target universal-apple-darwin",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "android:init": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run build && npx cap sync android && cd android && ./gradlew bundleRelease",
    "ios:init": "npx cap add ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1",
    "axios": "^1.7.2",
    "@tanstack/react-query": "^5.51.1",
    "zustand": "^4.5.4",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.408.0",
    "clsx": "^2.1.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.3.4",
    "tailwindcss": "^3.4.6",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "vitest": "^2.0.3",
    "@capacitor/core": "^6.1.0",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/push-notifications": "^6.0.1",
    "@capacitor/local-notifications": "^6.0.1",
    "@tauri-apps/cli": "^1.6.0",
    "@tauri-apps/api": "^1.6.0"
  }
}