{
  "info": {
    "name": "SwiftReply API",
    "description": "AI-Powered WhatsApp Business Messaging Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Organisation",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"org_name\": \"Acme Corp\", \"full_name\": \"Jane Smith\", \"email\": \"jane@acme.com\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"jane@acme.com\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "List Conversations",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/conversations?status=open&page=1&limit=20",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/conversations/CONVERSATION_ID/messages",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Resolve Conversation",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/conversations/CONVERSATION_ID/status",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"resolved\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Text Message",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/messages/send",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"conversation_id\": \"CONV_ID\", \"message_type\": \"text\", \"body\": \"Hello! How can I help you today?\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "List Contacts",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/contacts",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Contact",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/contacts",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone_number\": \"+260971234567\", \"display_name\": \"John Banda\", \"company\": \"Zambia Enterprises\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analytics/summary",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Verify Webhook",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/webhook?hub.mode=subscribe&hub.verify_token=YOUR_TOKEN&hub.challenge=test123"
          }
        },
        {
          "name": "Simulate Incoming Text",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/webhook",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"entry\": [{\"changes\": [{\"value\": {\"metadata\": {\"phone_number_id\": \"YOUR_PHONE_ID\"}, \"contacts\": [{\"profile\": {\"name\": \"Test User\"}}], \"messages\": [{\"from\": \"260971234567\", \"id\": \"wamid.test123\", \"type\": \"text\", \"text\": {\"body\": \"Hello, I need help with my order\"}, \"timestamp\": \"1700000000\"}]}}]}]}"
            }
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Generate Reply Suggestion",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/ai/generate-reply",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"conversation_id\": \"CONV_ID\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Broadcast",
      "item": [
        {
          "name": "Create & Send Broadcast",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/broadcasts",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Flash Sale\", \"message_body\": \"Hi! Check out our sale.\", \"message_type\": \"text\"}"
            }
          }
        },
        {
          "name": "Get Campaign Progress",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/broadcasts/CAMPAIGN_ID/progress",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Team / Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Invite User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/invite",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"agent@company.com\", \"full_name\": \"John Agent\", \"role\": \"agent\", \"password\": \"temp1234\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Evolution API",
      "item": [
        {
          "name": "Get QR Code",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/evolution/qr/swiftreply",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Connection Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/evolution/status/swiftreply",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ]
}