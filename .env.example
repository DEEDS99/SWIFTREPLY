# ============================================================
# SwiftReply — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- DATABASE ---
DATABASE_URL=postgresql://swiftreply_user:password@localhost:5432/swiftreply_db
# For Render.com, this is auto-injected from the database service

# --- SECURITY ---
SECRET_KEY=change-me-to-a-random-64-character-string-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- GOOGLE GEMINI AI ---
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com
GEMINI_MODEL=gemini-1.5-pro
# Gemini handles: text, images (jpg/png/webp), audio (mp3/wav/ogg), video (mp4/webm)

# --- META WHATSAPP BUSINESS CLOUD API ---
WHATSAPP_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verification-token
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_API_VERSION=v19.0
WHATSAPP_API_URL=https://graph.facebook.com

# --- MEDIA STORAGE (Cloudinary — optional, else uses local /uploads) ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
USE_CLOUDINARY=false

# --- FRONTEND ---
FRONTEND_URL=http://localhost:5173
# Production: https://your-app.onrender.com

# --- BACKEND ---
BACKEND_PORT=8000
DEBUG=true
# Production: DEBUG=false

# --- REDIS (optional — for rate limiting & caching) ---
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# --- EMAIL NOTIFICATIONS (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=SwiftReply <noreply@yourcompany.com>

# --- VITE FRONTEND ENV (prefix with VITE_) ---
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=SwiftReply

# --- EVOLUTION API (WhatsApp Web protocol — ToS compliant) ---
# Self-host Evolution API: https://github.com/EvolutionAPI/evolution-api
# Or use a managed provider
EVOLUTION_API_URL=https://your-evolution-server.com
EVOLUTION_API_KEY=your-evolution-global-api-key
EVOLUTION_INSTANCE=swiftreply
# The webhook URL Evolution will POST events to:
# https://your-backend.onrender.com/api/evolution/webhook
